{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Eimdall metrics source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "title": "Eimdall Fleet",
  "uid": "eimdall-fleet-v1",
  "description": "Eimdall fleet health, anomalies and platform metrics",
  "tags": ["eimdall", "robotics", "fleet"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(eimdall_fleet_robot_count, tenant_id)",
        "label": "Tenant",
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total robots",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(eimdall_fleet_robot_count{tenant_id=~\"$tenant\"})",
          "legendFormat": "Robots"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#a8d8f0" }, "thresholds": { "mode": "absolute", "steps": [] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Online robots",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(eimdall_fleet_online_count{tenant_id=~\"$tenant\"})",
          "legendFormat": "Online"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#ff4757", "value": null },
              { "color": "#ffa502", "value": 1 },
              { "color": "#2ed573", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Critical robots",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(eimdall_fleet_critical_count{tenant_id=~\"$tenant\"}) or vector(0)",
          "legendFormat": "Critical"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#2ed573", "value": null },
              { "color": "#ffa502", "value": 1 },
              { "color": "#ff4757", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Insights generated",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(eimdall_insights_total{tenant_id=~\"$tenant\"}) or vector(0)",
          "legendFormat": "Insights"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#a8d8f0" } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DailyReports ingested",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(eimdall_daily_reports_total{tenant_id=~\"$tenant\"}) or vector(0)",
          "legendFormat": "Reports"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#5ba8cc" } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Online robots over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tenant_id) (eimdall_fleet_online_count{tenant_id=~\"$tenant\"})",
          "legendFormat": "{{ tenant_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Anomaly events per hour",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tenant_id) (increase(eimdall_anomaly_events_total{tenant_id=~\"$tenant\"}[1h]))",
          "legendFormat": "{{ tenant_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 20,
      "type": "table",
      "title": "Robot status",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "eimdall_robot_online{tenant_id=~\"$tenant\"}",
          "legendFormat": "{{robot_id}}",
          "instant": true,
          "refId": "online"
        },
        {
          "expr": "eimdall_robot_last_seen_timestamp_seconds{tenant_id=~\"$tenant\"}",
          "legendFormat": "{{robot_id}}",
          "instant": true,
          "refId": "last_seen"
        },
        {
          "expr": "eimdall_anomaly_severity_last{tenant_id=~\"$tenant\"}",
          "legendFormat": "{{robot_id}}",
          "instant": true,
          "refId": "severity"
        },
        {
          "expr": "eimdall_anomaly_events_total{tenant_id=~\"$tenant\"}",
          "legendFormat": "{{robot_id}}",
          "instant": true,
          "refId": "total"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "robot_id": "Robot",
              "tenant_id": "Tenant",
              "Value #online": "Online",
              "Value #last_seen": "Last seen",
              "Value #severity": "Last severity",
              "Value #total": "Anomalies total"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Online" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "#ff4757" }, "1": { "text": "ONLINE", "color": "#2ed573" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last seen" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": {
                    "1": { "text": "LOW" },
                    "2": { "text": "MEDIUM", "color": "#ffa502" },
                    "3": { "text": "HIGH", "color": "#ff4757" },
                    "4": { "text": "CRITICAL", "color": "#ff4757" }
                  }}
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Insights generated (cumulative)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tenant_id) (eimdall_insights_total{tenant_id=~\"$tenant\"})",
          "legendFormat": "{{ tenant_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#a8d8f0" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "DailyReports ingested (cumulative)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tenant_id) (eimdall_daily_reports_total{tenant_id=~\"$tenant\"})",
          "legendFormat": "{{ tenant_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#5ba8cc" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    }
  ]
}
